FAST_MODEL_ID=lfm2.5:8b
VISION_MODEL_ID=minicpm4.5:8b
EMBEDDING_MODEL_ID=nomic-embed-text
MAIN_MODEL_URL=http://127.0.0.1:8081/v1/chat/completions
