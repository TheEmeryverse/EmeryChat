ENABLE_REOLINK=false
ENABLE_SCHEDULER=true
ENABLE_HEARTBEAT=true
ENABLE_MEMORY=true
ENABLE_TELEGRAM_RICH_MESSAGES=true
ENABLE_ROUTINE_CACHE_WARMUP=true
