TELEGRAM_TOKEN=YOUR_TELEGRAM_TOKEN # Generated using @BotFather on Telegram

# Model information
MODEL_NAME=Emery
MODEL_ID=qwen3.6:35b-a3b
VISION_MODEL_ID=gemma4:e4b

OPEN_WEBUI_URL=http://localhost:3000/api/v1/chat/completions
OPEN_WEBUI_KEY=YOUR_OPEN_WEBUI_KEY

STT_URL=http://localhost:3000/api/v1/audio/transcriptions

# User bio
USER_NAME=User
USER_GENDER=Male
USER_BIRTHDAY="January 1, 2000"
USER_FAMILY="Wife, Jessica, born June 7 1999. Son, Adam, born August 18 2022."
USER_LOCATION="New York City, NY"
USER_TIMEZONE="America/New York"
USER_PROFESSION="AI Enthusiast"

ENABLE_CALENDAR=true # Uses Google Studio API Key
GOOGLE_CALENDAR_IDS=primary # Separate multiple calendars with commas
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

ENABLE_WEATHER=true # Uses NOAA API
NOAA_LAT=YOUR_LOCATION_LATITUDE
NOAA_LONG=YOUR_LOCATION_LONGITUDE
NOAA_EMAIL=example@example.com

ENABLE_NEWS=true # Uses RSS News Feeds
NEWS_FEEDS="REUTERS|https://news.google.com/rss/search?q=when:24h+source:reuters&hl=en-US&gl=US&ceid=US:en, FOX|http://feeds.foxnews.com/foxnews/latest, TECH|https://news.google.com/rss/search?q=when:24h+technology&hl=en-US&gl=US&ceid=US:en" # Format: "NAME|URL,NAME|URL,NAME|URL"

ENABLE_NASA=true # Uses NASA's API
NASA_API_KEY=YOUR_NASA_API_KEY

ENABLE_SEERR=true # Uses Seerr's API
OVERSEER_URL=http://localhost:5055/api/v1
OVERSEER_KEY=YOUR_OVERSEER_KEY
OVERSEER_USER_ID=1

ENABLE_HISTORY=true # Uses todayinhistory.com API

ENABLE_VOICE=true # Uses Kokoro's API
TTS_URL=http://localhost:8880/v1/audio/speech
TTS_VOICE=af_heart

ENABLE_IMAGEGEN=true # Uses Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
IMAGE_MODEL=gemini-3.1-flash-image-preview

ENABLE_SEARCH=true # Uses SearXNG
SEARXNG_URL=http://localhost:8080/search
ENABLE_WEB_SCRAPING=true # For grabbing specific URLs

ENABLE_SYSTEM_STATS=true # Uses local system stats

TOOL_LOOP=15 # How many times the model can call tools in one turn before generating a response, prevents looping behavior