TELEGRAM_TOKEN=YOUR_TELEGRAM_TOKEN # Generated using @BotFather on Telegram

# Telegram Chat Group, Topics, and Whitelist Privacy Config (Optional)
TELEGRAM_GROUP_CHAT_ID=-100XXXXXXXXXX # Dedicated group chat ID
SECURITY_TOPIC_ID=111 # Topic thread ID for Security alerts (Reolink)
ROUTINES_TOPIC_ID=222 # Topic thread ID for Daily scheduled background jobs
CHAT_TOPIC_ID=333 # Topic thread ID for general chatting, reminders, and heartbeats
REOLINK_SILENT_ALERTS=true # Default: true. Set to false to enable alert sounds
TELEGRAM_ALLOWED_USERS=123456789,987654321 # Comma-separated User IDs allowed to talk to the bot

# Model information
MODEL_NAME=Emery
MODEL_ID=qwen3.6:35b-a3b
VISION_MODEL_ID=gemma4:e4b
OLLAMA_NUM_CTX=65536 # The context size for Ollama requests (main text model)
OLLAMA_VISION_NUM_CTX=65536 # The context size for Ollama requests (vision model)

OPEN_WEBUI_URL=http://localhost:3000/api/v1/chat/completions
OPEN_WEBUI_KEY=YOUR_OPEN_WEBUI_KEY

STT_URL=http://localhost:3000/api/v1/audio/transcriptions

# User bio
USER_NAME=User
USER_GENDER=Male
USER_BIRTHDAY="January 1, 2000"
USER_FAMILY="Spouse, Jane, born January 1 1990. Child, Alex, born January 1 2020."
USER_LOCATION="New York City, NY"
USER_TIMEZONE="America/New_York"
USER_PROFESSION="AI Enthusiast"
USER_RELATIONSHIP="married" # Optional. Describes the relationship between USER_NAME and USER_2_NAME (e.g. "married", "siblings", "friends")

ENABLE_CALENDAR=true # Uses Google Studio API Key
GOOGLE_CALENDAR_IDS=primary # Separate multiple calendars with commas
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

ENABLE_WEATHER=true # Uses NOAA API
NOAA_LAT=YOUR_LOCATION_LATITUDE
NOAA_LONG=YOUR_LOCATION_LONGITUDE
NOAA_EMAIL=example@example.com

ENABLE_NEWS=true # Uses RSS News Feeds
NEWS_FEEDS="REUTERS|https://news.google.com/rss/search?q=when:24h+source:reuters&hl=en-US&gl=US&ceid=US:en, FOX|http://feeds.foxnews.com/foxnews/latest, TECH|https://news.google.com/rss/search?q=when:24h+technology&hl=en-US&gl=US&ceid=US:en" # Format: "NAME|URL,NAME|URL,NAME|URL"

ENABLE_NASA=true # Uses NASA's API
NASA_API_KEY=YOUR_NASA_API_KEY

ENABLE_SEERR=true # Uses Seerr's API
OVERSEER_URL=http://localhost:5055/api/v1
OVERSEER_KEY=YOUR_OVERSEER_KEY
OVERSEER_USER_ID=1

ENABLE_HISTORY=true # Uses todayinhistory.com API

ENABLE_VOICE=true # Uses Kokoro's API
TTS_URL=http://localhost:8880/v1/audio/speech
TTS_VOICE=af_heart

ENABLE_IMAGEGEN=true # Uses Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
IMAGE_MODEL=gemini-3.1-flash-image-preview

ENABLE_SEARCH=true # Uses SearXNG
SEARXNG_URL=http://localhost:8080/search
ENABLE_WEB_SCRAPING=true # For grabbing specific URLs

ENABLE_SYSTEM_STATS=true # Uses local system stats

# Reolink Camera Integration
ENABLE_REOLINK=false
REOLINK_HOST=YOUR_REOLINK_NVR_IP
REOLINK_USER=YOUR_REOLINK_USER
REOLINK_PASSWORD=YOUR_REOLINK_PASSWORD
REOLINK_CAMERAS=frontdoor:0,backdoor:1  # Mappings of camera names to channels
ENABLE_REOLINK_POLLING=false
ENABLE_REOLINK_THREADING=true
REOLINK_THREAD_WINDOW_MINUTES=10

# Google Nest Thermostat
ENABLE_NEST=false
NEST_PROJECT_ID=YOUR_NEST_DEVICE_ACCESS_PROJECT_ID
NEST_TOKEN_PATH=nest_token.json

# Dynamic Scheduler Config
ENABLE_SCHEDULER=true
JOBS_FILE_PATH=custom_jobs.json

MAX_HISTORY_LEN=200 # Max chat history message count (user/assistant/tool messages) to store in active memory
TOOL_LOOP=15 # How many times the model can call tools in one turn before generating a response, prevents looping behavior

# Inactivity Heartbeat & Spontaneous Check-ins
ENABLE_HEARTBEAT=true
HEARTBEAT_INTERVAL_SECONDS=3600 # Frequency in seconds to check chat inactivity (default: 1 hour)
HEARTBEAT_SILENCE_THRESHOLD_SECONDS=14400 # Seconds of chat silence required to trigger check-in (default: 4 hours)
HEARTBEAT_SLEEP_START=21:30 # User's bedtime start in 24h format (default: 9:30 PM)
HEARTBEAT_SLEEP_END=03:30 # User's bedtime end in 24h format (default: 3:30 AM)

# Stickers & GIFs integrations (Optional)
TELEGRAM_STICKER_SET=Classic # Preloads this sticker set name on startup (e.g. Classic, Animals, etc.)
GIPHY_API_KEY=YOUR_GIPHY_API_KEY # Optional. Falls back to a public test key if omitted
TENOR_API_KEY=YOUR_TENOR_API_KEY # Optional. Falls back to a public test key if omitted